# ============================================================================
# Yuxi-Know 环境变量配置模板
# ============================================================================
# 复制此文件为 .env 并根据实际情况修改配置
# 部署脚本会自动从 CONFIG_DIR/env/.env 优先读取配置
# ============================================================================

# ============================ 模型提供商配置 ============================
# 推荐使用硅基流动免费服务 https://cloud.siliconflow.cn/i/Eo5yTHGJ
# SILICONFLOW_API_KEY=

# Tavily 搜索服务（用于增强知识库搜索）
# 获取 API Key 请访问 https://app.tavily.com/
# TAVILY_API_KEY=

# 其他可选的模型提供商（按需启用）
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# ZHIPUAI_API_KEY=
# DASHSCOPE_API_KEY=
# DEEPSEEK_API_KEY=
# ARK_API_KEY=
# TOGETHER_API_KEY=

# ============================ 数据库配置 ============================

# PostgreSQL 数据库配置
# POSTGRES_USER - PostgreSQL 用户名（默认: postgres）
# POSTGRES_USER=postgres

# POSTGRES_PASSWORD - PostgreSQL 密码（默认: postgres，生产环境请修改）
# POSTGRES_PASSWORD=postgres

# POSTGRES_DB - PostgreSQL 数据库名（默认: yuxi_know）
# POSTGRES_DB=yuxi_know

# PostgreSQL 数据库配置
# POSTGRES_PORT - PostgreSQL 端口（默认: 5432）
# POSTGRES_PORT=5432

# POSTGRES时区设置（默认: Asia/Shanghai）
# TZ=Asia/Shanghai

# Neo4j 图数据库配置
# NEO4J_URI - Neo4j 连接地址（默认: bolt://graph:7687）
# NEO4J_URI=bolt://graph:7687

# NEO4J_USERNAME - Neo4j 用户名（默认: neo4j）
# NEO4J_USERNAME=neo4j

# NEO4J_PASSWORD - Neo4j 密码（默认: 0123456789，生产环境请修改）
# NEO4J_PASSWORD=0123456789

# Milvus 向量数据库配置
# MILVUS_URI - Milvus 连接地址（默认: http://milvus:19530）
# MILVUS_URI=http://milvus:19530

# MILVUS_DB_NAME - Milvus 数据库名（默认: default）
# MILVUS_DB_NAME=default

# MILVUS_TOKEN - Milvus 访问令牌（默认为空）
# MILVUS_TOKEN=

# ============================ MinIO 对象存储配置 ============================
# MINIO_URI - MinIO API 地址（默认: http://milvus-minio:9000）
# MINIO_URI=http://milvus-minio:9000

# MINIO_ACCESS_KEY - MinIO 访问密钥（默认: minioadmin）
# MINIO_ACCESS_KEY=minioadmin

# MINIO_SECRET_KEY - MinIO 密钥（默认: minioadmin）
# MINIO_SECRET_KEY=minioadmin


# ============================ 应用配置 ============================

# 超级管理员账户（首次部署时创建）
# 用于快速创建管理员账户，生产环境建议部署后通过 Web 界面创建
# YUXI_SUPER_ADMIN_NAME=admin
# YUXI_SUPER_ADMIN_PASSWORD=admin123

# URL 白名单（逗号分隔的域名/IP，为空则禁用 URL 解析）
# 用于限制可从外部 URL 解析的域名，防止恶意 URL 访问
# YUXI_URL_WHITELIST=github.com,docs.example.com,gitlab.example.com,127.0.0.1

# MinerU API Key（如果需要认证）
# 用于 MinerU 服务的访问认证
# MINERU_API_KEY=

# ============================ OAuth2 SSO 单点登录配置 ============================
# SSO 是否启用（默认: false）
# SSO_ENABLED=false

# SSO 授权端点 URL
# SSO_AUTHORIZATION_URL=https://auth.example.com/oauth2/authorize

# SSO Token 端点 URL
# SSO_TOKEN_URL=https://auth.example.com/oauth2/token

# SSO 用户信息端点 URL
# SSO_USER_INFO_URL=https://auth.example.com/oauth2/userinfo

# SSO Token 内省端点 URL（可选，用于验证 Token 有效性）
# SSO_INTROSPECT_URL=https://auth.example.com/oauth2/introspect

# SSO 客户端 ID
# SSO_CLIENT_ID=yuxi-know

# SSO 客户端密钥（生产环境请使用强密码）
# SSO_CLIENT_SECRET=your-client-secret

# SSO 回调地址（前端回调页面地址）
# SSO_REDIRECT_URI=http://localhost:5173/sso/callback

# SSO 授权范围（ openid profile email）
# SSO_SCOPE=openid profile email

# 用户字段映射配置
# SSO 用户名字段（认证中心返回用户名的字段名）
# SSO_FIELD_MAPPING_USERNAME=username

# SSO 用户ID字段（认证中心返回用户唯一标识的字名）
# SSO_FIELD_MAPPING_USERID=sub

# SSO 手机号字段（认证中心返回手机号的字段名）
# SSO_FIELD_MAPPING_PHONE=phone_number

# SSO 头像字段（认证中心返回头像URL的字段名）
# SSO_FIELD_MAPPING_AVATAR=picture

# SSO 邮箱字段（认证中心返回邮箱的字段名）
# SSO_FIELD_MAPPING_EMAIL=email
