# ============================================================================
# Yuxi-Know 环境变量配置模板
# ============================================================================
# 复制此文件为 .env 并根据实际情况修改配置
# 部署脚本会自动从 CONFIG_DIR/env/.env 优先读取配置
# ============================================================================

# ============================ 数据卷路径配置 ============================
# 注意: 所有路径变量已统一命名，部署脚本和 Docker Compose 使用相同的变量名

# 数据卷根目录（所有数据目录的父目录）
# 部署脚本会自动生成并写入 .env
# DATA_ROOT=/app/data

# SAVE_DIR    - 保存目录根路径（默认: ./docker/volumes）
# MODEL_DIR   - 模型目录根路径（默认: ./models）

# 数据库数据卷路径（部署脚本会自动生成）
# POSTGRES_DATA_DIR - PostgreSQL 数据目录（默认: ./docker/volumes/postgresql）
# NEO4J_DATA_DIR     - Neo4j 数据目录（默认: ./docker/volumes/neo4j）
# MILVUS_DATA_DIR    - Milvus 数据目录（默认: ./docker/volumes/milvus）
# PADDLEX_DATA_DIR   - PaddleX 数据目录（默认: ./docker/volumes/paddlex）

# ============================ 模型提供商配置 ============================
# 推荐使用硅基流动免费服务 https://cloud.siliconflow.cn/i/Eo5yTHGJ
# SILICONFLOW_API_KEY=

# Tavily 搜索服务（用于增强知识库搜索）
# 获取 API Key 请访问 https://app.tavily.com/
# TAVILY_API_KEY=

# 其他可选的模型提供商（按需启用）
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# ZHIPUAI_API_KEY=
# DASHSCOPE_API_KEY=
# DEEPSEEK_API_KEY=
# ARK_API_KEY=
# TOGETHER_API_KEY=

# ============================ 数据库配置 ============================

# PostgreSQL 数据库配置
# POSTGRES_URL - 完整的数据库连接 URL（如果不设置，将使用下面的单独配置）
# POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/yuxi_know

# POSTGRES_USER - PostgreSQL 用户名（默认: postgres）
# POSTGRES_USER=postgres

# POSTGRES_PASSWORD - PostgreSQL 密码（默认: postgres，生产环境请修改）
# POSTGRES_PASSWORD=postgres

# POSTGRES_DB - PostgreSQL 数据库名（默认: yuxi_know）
# POSTGRES_DB=yuxi_know

# Neo4j 图数据库配置
# NEO4J_URI - Neo4j 连接地址（默认: bolt://graph:7687）
# NEO4J_URI=bolt://graph:7687

# NEO4J_USERNAME - Neo4j 用户名（默认: neo4j）
# NEO4J_USERNAME=neo4j

# NEO4J_PASSWORD - Neo4j 密码（默认: 0123456789，生产环境请修改）
# NEO4J_PASSWORD=0123456789

# Milvus 向量数据库配置
# MILVUS_URI - Milvus 连接地址（默认: http://milvus:19530）
# MILVUS_URI=http://milvus:19530

# MILVUS_DB_NAME - Milvus 数据库名（默认: default）
# MILVUS_DB_NAME=default

# MILVUS_TOKEN - Milvus 访问令牌（默认为空）
# MILVUS_TOKEN=

# ============================ MinIO 对象存储配置 ============================
# MINIO_URI - MinIO API 地址（默认: http://milvus-minio:9000）
# MINIO_URI=http://milvus-minio:9000

# MINIO_ACCESS_KEY - MinIO 访问密钥（默认: minioadmin）
# MINIO_ACCESS_KEY=minioadmin

# MINIO_SECRET_KEY - MinIO 密钥（默认: minioadmin）
# MINIO_SECRET_KEY=minioadmin

# ============================ 服务间通信配置 ============================
# 注意: 这些默认值适用于 Docker Compose 内部网络通信
# 修改前请确保网络配置正确

# HOST_IP - Docker 宿主机 IP（用于从容器内访问宿主机服务，默认为空）
# 如主机访问容器内的服务，通常不需要设置此变量
# HOST_IP=

# MinerU 服务地址
# MINERU_VL_SERVER - MinerU VLLM 服务地址（默认: http://mineru-vllm-server:30000）
# MINERU_VL_SERVER=http://mineru-vllm-server:30000

# MINERU_API_URI - MinerU API 地址（默认: http://mineru-api:30001）
# MINERU_API_URI=http://mineru-api:30001

# PADDLEX_URI - PaddleX OCR 服务地址（默认: http://paddlex:8080）
# PADDLEX_URI=http://paddlex:8080

# ============================ 系统配置 ============================
# TZ - 时区设置（默认: Asia/Shanghai）
# TZ=Asia/Shanghai

# ============================ 应用配置 ============================

# 超级管理员账户（首次部署时创建）
# 用于快速创建管理员账户，生产环境建议部署后通过 Web 界面创建
# YUXI_SUPER_ADMIN_NAME=admin
# YUXI_SUPER_ADMIN_PASSWORD=admin123

# URL 白名单（逗号分隔的域名/IP，为空则禁用 URL 解析）
# 用于限制可从外部 URL 解析的域名，防止恶意 URL 访问
# YUXI_URL_WHITELIST=github.com,docs.example.com,gitlab.example.com,127.0.0.1

# MinerU API Key（如果需要认证）
# 用于 MinerU 服务的访问认证
# MINERU_API_KEY=
